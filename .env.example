# ──────────────────────────────────────────────────────────────
#  Copy this file to `.env.local` and fill in real values.
#  `.env.local` is gitignored — NEVER commit real keys.
#
#  The app runs fully in MOCK mode with NONE of these set,
#  so you can `npm run dev` immediately after cloning.
# ──────────────────────────────────────────────────────────────

# ── Natural-language parser (pick one; priority: Anthropic > Groq > rules) ──
#
# Groq — FREE API (https://console.groq.com, no credit card). Runs open models
# (Llama 3.3 70B) and is OpenAI-compatible. Good free default.
GROQ_API_KEY=
# Optional: point at any other OpenAI-compatible endpoint (OpenRouter, local Ollama, …)
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_BASE_URL=https://api.groq.com/openai/v1

# Anthropic (Claude) — paid but most accurate. Takes priority over Groq if set.
# Get one at https://console.anthropic.com/
# With NEITHER key set, a built-in rule-based Korean parser is used.
ANTHROPIC_API_KEY=

# Korea Investment & Securities (KIS) Open API — live quotes & charts
# Get keys at https://apiportal.koreainvestment.com/  (모의투자 계좌 추천)
# Without these, charts use deterministic mock candles.
KIS_APP_KEY=
KIS_APP_SECRET=

# Use the simulation (모의투자) endpoint? "true" -> openapivts, else live.
KIS_USE_SIMULATION=true
