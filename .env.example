# ──────────────────────────────────────────────────────────────
#  Copy this file to `.env.local` and fill in real values.
#  `.env.local` is gitignored — NEVER commit real keys.
#
#  The app runs fully in MOCK mode with NONE of these set,
#  so you can `npm run dev` immediately after cloning.
# ──────────────────────────────────────────────────────────────

# Anthropic (Claude) — natural-language query -> filter JSON
# Get one at https://console.anthropic.com/
# Without it, a built-in rule-based Korean parser is used instead.
ANTHROPIC_API_KEY=

# Korea Investment & Securities (KIS) Open API — live quotes & charts
# Get keys at https://apiportal.koreainvestment.com/  (모의투자 계좌 추천)
# Without these, charts use deterministic mock candles.
KIS_APP_KEY=
KIS_APP_SECRET=

# Use the simulation (모의투자) endpoint? "true" -> openapivts, else live.
KIS_USE_SIMULATION=true
